# ============================================================
# .env.example
# Copia este archivo a .env y rellena con valores reales.
# Cada variable indica desde qué Milestone se necesita.
# ============================================================

# ------------------------------------------------------------
# Aplicación (Milestone 1+)
# ------------------------------------------------------------
APP_NAME=agente-gastronomia-colombiana
APP_ENV=development                    # development | production
DEBUG=true
LOG_LEVEL=INFO

# ------------------------------------------------------------
# Base de datos PostgreSQL + pgvector (Milestone 2+)
# Local: usar el servicio de docker-compose (host=postgres)
# Producción: apuntar a RDS
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://agente_user:agente_password@postgres:5432/agente_db
POSTGRES_USER=agente_user
POSTGRES_PASSWORD=agente_password
POSTGRES_DB=agente_db

# ------------------------------------------------------------
# Ollama - Modelo local (Milestone 5+)
# ------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# ------------------------------------------------------------
# Embeddings - HuggingFace (Milestone 4+)
# ------------------------------------------------------------
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIMENSION=384

# ------------------------------------------------------------
# RAG - Parámetros del agente (Milestone 5+)
# ------------------------------------------------------------
SIMILARITY_THRESHOLD=0.70              # Umbral mínimo para considerar contexto relevante
TOP_K=5                                # Cantidad de chunks a recuperar
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ------------------------------------------------------------
# AWS Cognito (Milestone 3+)
# Crear User Pool en us-east-1 y rellenar
# ------------------------------------------------------------
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=                  # Ej: us-east-1_xxxxxxxxx
COGNITO_APP_CLIENT_ID=                 # Ej: 1a2b3c4d5e6f7g8h9i0j

# ------------------------------------------------------------
# AWS S3 (Milestone 4+)
# Bucket para guardar archivos originales subidos por usuarios
# ------------------------------------------------------------
AWS_REGION=us-east-1
AWS_S3_BUCKET=                         # Ej: agente-gastronomia-files-tunombre
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ------------------------------------------------------------
# CORS (Milestone 6+)
# URLs permitidas del frontend, separadas por coma
# ------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
