# ============================================================
# .env.example
# Copia este archivo a .env y rellena con valores reales.
# ============================================================

# ------------------------------------------------------------
# Aplicación (Milestone 1+)
# ------------------------------------------------------------
APP_NAME=agente-gastronomia-colombiana
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ------------------------------------------------------------
# Base de datos PostgreSQL + pgvector (Milestone 2+)
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://agente_user:agente_password@postgres:5432/agente_db
POSTGRES_USER=agente_user
POSTGRES_PASSWORD=agente_password
POSTGRES_DB=agente_db

# ------------------------------------------------------------
# Ollama (Milestone 5+)
# ------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=60                # Timeout en segundos para llamadas al LLM

# ------------------------------------------------------------
# Embeddings - HuggingFace (Milestone 4+)
# ------------------------------------------------------------
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIMENSION=384

# ------------------------------------------------------------
# RAG / Chunking (Milestones 4 y 5)
# ------------------------------------------------------------
SIMILARITY_THRESHOLD=0.70                # Mín. similitud para considerar contexto relevante
TOP_K=5                                  # Cantidad de chunks a recuperar
CHUNK_SIZE=800                           # Caracteres por chunk
CHUNK_OVERLAP=150                        # Solapamiento entre chunks

# ------------------------------------------------------------
# Chat (Milestone 5+)
# ------------------------------------------------------------
HISTORY_MAX_MESSAGES=6                   # Últimos N mensajes en el prompt
MAX_QUESTION_LENGTH=800                  # Longitud máx. de pregunta en caracteres

# ------------------------------------------------------------
# Upload de documentos (Milestone 4+)
# ------------------------------------------------------------
MAX_UPLOAD_SIZE_BYTES=20971520           # 20 MB
ALLOWED_MIME_TYPES=application/pdf,text/plain,text/markdown,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ------------------------------------------------------------
# AWS Cognito (Milestone 3+)
# ------------------------------------------------------------
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=

# ------------------------------------------------------------
# AWS S3 (Milestone 4+)
# ------------------------------------------------------------
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ------------------------------------------------------------
# CORS (Milestone 6+)
# ------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
